<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- Recording stops when the entire screen is exactly this colour.
         Accepts hex ("#000000") or named colours ("Black").
         Must match the TerminationColor in PhotoFrameApp's appsettings.json. -->
    <add key="TerminationColor" value="#000000" />
    <!-- Which monitor to record: 0 = primary screen, 1..N = detected screen
         number. The recorder lists detected screens when it starts. -->
    <add key="CaptureScreen" value="0" />
  </appSettings>
</configuration>
