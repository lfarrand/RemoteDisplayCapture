{
  // Colour shown around images smaller than the monitor resolution.
  // Accepts named colours ("DarkSlateGray") or hex ("#RRGGBB").
  "BorderColor": "#202020",

  // Colour of the end-of-sequence screen held when running with the "once"
  // argument. This is the stop signal for PhotoFrameRecorder - keep it in
  // sync with TerminationColor in the recorder's App.config.
  "TerminationColor": "#000000",

  // Which monitor shows the photos: 0 = primary screen, 1..N = detected
  // screen number (the app lists detected screens if the value is invalid).
  "DisplayScreen": 0
}
