<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- Recording stops when the entire screen is this colour.
         Accepts hex ("#000000") or named colours ("Black").
         Must match the TerminationColor in RemoteDisplayCapture.Display's appsettings.json. -->
    <add key="TerminationColor" value="#000000" />
    <!-- Per-channel slack (0-255) when matching the termination colour. HDR or
         auto colour management can shift composed colours substantially (a
         measured example: #404040 captured as #272727, a shift of 25), so exact
         matching may never fire for non-black colours. With a non-zero
         tolerance the recorder stops when the screen is UNIFORM (all pixels
         near-identical) and that colour is within tolerance of the termination
         colour - so pick a termination colour unlike any solid full-screen
         image you plan to display. 0 = exact match only. -->
    <add key="TerminationTolerance" value="30" />
    <!-- true: capture the compositor's native HDR frames (FP16 scRGB) and save
         32-bit float TIFFs. Preserves the HDR composition exactly, but files
         are huge (~130 MB per 4K frame after widening; the save queue shrinks
         accordingly) and it only works while the captured screen is
         HDR-composed. Keep TerminationColor black in this mode: matching other
         colours assumes SDR white at scRGB 1.0, which varies per system.
         false (default): standard 8-bit capture. -->
    <add key="HdrCapture" value="false" />
    <!-- Which monitor to record: 0 = primary screen, 1..N = detected screen
         number. The recorder lists detected screens when it starts. -->
    <add key="CaptureScreen" value="0" />
    <!-- Lossless capture format: png (default, compressed), tiff (LZW
         compressed), or bmp (uncompressed, fastest to write but ~33 MB per
         4K frame). GIF is not offered because it quantizes to 256 colours. -->
    <add key="OutputFormat" value="png" />
  </appSettings>
</configuration>
